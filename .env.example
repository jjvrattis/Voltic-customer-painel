# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://painel.expressvoltic.com.br,http://localhost:3001

# ── Mercado Livre ─────────────────────────────────────────────────────────────
ML_APP_ID=<app-id>
ML_CLIENT_SECRET=<client-secret>
ML_REDIRECT_URI=https://api.expressvoltic.com.br/api/v1/auth/ml/callback

# ── Shopee ────────────────────────────────────────────────────────────────────
SHOPEE_PARTNER_ID=<partner-id>
SHOPEE_PARTNER_KEY=<partner-key>
SHOPEE_REDIRECT_URI=https://api.expressvoltic.com.br/api/v1/auth/shopee/callback

# ── AbacatePay ────────────────────────────────────────────────────────────────
ABACATEPAY_API_KEY=<api-key>
ABACATEPAY_WEBHOOK_SECRET=<webhook-secret>
